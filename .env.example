# ================================================================
# JARVIS MAX — Environment Configuration
# ================================================================
# SETUP
#   cp .env.example .env
#   Edit the CHANGE_ME values (minimum: one LLM key + secret)
#   Never commit .env to git
#
# PROVEN BOOT PATH (verified 2026-04-01):
#   1. Set ANTHROPIC_API_KEY (or another LLM key below)
#   2. Start Qdrant on localhost:6333
#   3. python main.py
#   4. bash scripts/verify_boot.sh   → exits 0 in ~40s
# ================================================================

# ── Identity ────────────────────────────────────────────────
JARVIS_NAME=JarvisMax
JARVIS_VERSION=2.0.0
# Generate: openssl rand -hex 32
JARVIS_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ================================================================
# LLM PROVIDER — choose ONE path and uncomment it
# ================================================================

# ── PATH A: Anthropic (PROVEN — recommended for first run) ───
# pip install langchain-anthropic
# MODEL_FALLBACK=anthropic ensures all roles use Anthropic when
# OPENROUTER_API_KEY is not set (the internal role router defaults
# to openrouter, falls back to anthropic on missing key).
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MODEL_STRATEGY=anthropic
MODEL_FALLBACK=anthropic

# ── PATH B: OpenRouter (cloud gateway — routes to 200+ models) ─
# Sign up at https://openrouter.ai to get a key.
# pip install langchain-openai  (required for OpenRouter provider)
# OPENROUTER_API_KEY=sk-or-CHANGE_ME
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MODEL_STRATEGY=openrouter
# MODEL_FALLBACK=anthropic   # fallback if OpenRouter fails
# Role-based model defaults (override as needed):
# ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4.5
# CODER_MODEL=anthropic/claude-sonnet-4.5
# ARCHITECT_MODEL=anthropic/claude-sonnet-4.5
# SELF_IMPROVEMENT_MODEL=anthropic/claude-sonnet-4.5
# FAST_MODEL=openai/gpt-4o-mini
# FALLBACK_MODEL=openai/gpt-4o-mini

# ── PATH C: OpenAI direct ──────────────────────────────────
# OPENAI_API_KEY=sk-CHANGE_ME
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini
# MODEL_STRATEGY=openai
# MODEL_FALLBACK=openai

# ── PATH D: Ollama (local, no API key required) ─────────────
# Requires: ollama serve + at least one model pulled
# MODEL_STRATEGY=ollama
# MODEL_FALLBACK=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL_MAIN=llama3.1:8b
# OLLAMA_MODEL_CODE=deepseek-coder-v2:16b
# OLLAMA_MODEL_FAST=mistral:7b

# ================================================================
# VECTOR MEMORY — Qdrant (required at runtime)
# ================================================================
# Dev (native binary):
#   wget https://github.com/qdrant/qdrant/releases/download/v1.9.7/qdrant-x86_64-unknown-linux-musl.tar.gz
#   tar xzf qdrant-*.tar.gz && ./qdrant
# Docker: docker run -p 6333:6333 qdrant/qdrant:v1.9.7
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY is optional for local dev. Set it for production.
# Must match QDRANT__SERVICE__API_KEY in docker-compose if used.
# QDRANT_API_KEY=CHANGE_ME_qdrant_api_key

# ================================================================
# AUTH
# ================================================================
JARVIS_ADMIN_USER=admin
JARVIS_ADMIN_PASSWORD=CHANGE_ME_admin_password
# Static API token for script/programmatic access
# Generate: openssl rand -hex 32
JARVIS_API_TOKEN=CHANGE_ME_api_token_min_32_chars

# ================================================================
# DATABASE — PostgreSQL (optional in dev, required in production)
# ================================================================
# Persistence truth (as of 2026-04-01):
#   - Canonical missions (/api/v3 path) → SQLite workspace/canonical_missions.db, survives restarts. ✅
#   - Legacy missions (MissionSystem path) → SQLite workspace/jarvismax.db + JSON fallback. ✅
#   - Postgres → used for auth, audit, kernel data when configured (not required for dev).
# Set JARVIS_PRODUCTION=1 to block startup if secrets are insecure (does not check Postgres availability).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here
POSTGRES_DB=jarvis

# ── Redis (optional — degrades gracefully if absent) ────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=CHANGE_ME_redis_password

# ================================================================
# RUNTIME BEHAVIOR
# ================================================================
DRY_RUN=false
MAX_AUTO_ACTIONS=25
JARVIS_MODE=local      # local | vps

# Production safety: uncomment to enforce persistence + secret checks at boot.
# Startup blocks with a clear error if Postgres, secrets, or LLM key are missing.
# JARVIS_PRODUCTION=1

# ── Self-Improvement ────────────────────────────────────────
SELF_IMPROVE_ENABLED=true
SELF_IMPROVE_MAX_PATCHES=5

# ================================================================
# OBSERVABILITY (all optional)
# ================================================================
LANGFUSE_ENABLED=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=JarvisMax
# LANGCHAIN_API_KEY=
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
# LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME

# ================================================================
# OPTIONAL SERVICES (not required for core mission path)
# ================================================================
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
RATE_LIMIT_REDIS=false
# CORS_ORIGINS=https://app.example.com,http://localhost:3000
# N8N_HOST=http://n8n:5678
# N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_key
# TELEGRAM_BOT_TOKEN=SET_ME
# TELEGRAM_TARGET_CHAT_ID=SET_ME

# ================================================================
# DOCKER RESOURCE LIMITS
# ================================================================
OLLAMA_MEMORY_LIMIT=8g
JARVIS_MEMORY_LIMIT=4g
