# ================================================================
# JARVIS MAX — Configuration
# ================================================================
# 1. cp .env.example .env
# 2. Fill in the CHANGE_ME values
# 3. python main.py   (or docker compose up -d)
# ⚠️ Never commit .env to git
# ================================================================

# ── Identity ────────────────────────────────────────────────
JARVIS_NAME=JarvisMax
JARVIS_VERSION=2.0.0
JARVIS_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Primary LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# ── Optional LLMs ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro

# ── LLM Strategy ────────────────────────────────────────────
# openai | anthropic | google | ollama
MODEL_STRATEGY=openai
MODEL_FALLBACK=ollama

# ── Ollama (local LLM) ──────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL_MAIN=llama3.1:8b
OLLAMA_MODEL_CODE=deepseek-coder-v2:16b
OLLAMA_MODEL_FAST=mistral:7b
OLLAMA_MODEL_VISION=llava:7b
OLLAMA_MODEL_UNCENSORED=dolphin-mixtral

# ── Database ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here
POSTGRES_DB=jarvis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Vector Memory ────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# API key Qdrant — OBLIGATOIRE en production (doit correspondre à QDRANT__SERVICE__API_KEY dans docker-compose)
# Générer : openssl rand -hex 32
QDRANT_API_KEY=CHANGE_ME_qdrant_api_key

# ── n8n (automation) ────────────────────────────────────────
N8N_HOST=http://n8n:5678
N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password

# ── Runtime ──────────────────────────────────────────────────
DRY_RUN=false
MAX_AUTO_ACTIONS=25
JARVIS_MODE=local   # local | vps

# ── Self-Improvement ────────────────────────────────────────
SELF_IMPROVE_ENABLED=true
SELF_IMPROVE_MAX_PATCHES=5

# ── Browser ──────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# ── Auth API ─────────────────────────────────────────────────
# Token statique (scripts / accès programmatique) — générer : openssl rand -hex 32
JARVIS_API_TOKEN=CHANGE_ME_api_token_min_32_chars
# Utilisateur admin principal (fallback sur JARVIS_SECRET_KEY si JARVIS_ADMIN_PASSWORD absent)
JARVIS_ADMIN_USER=admin
JARVIS_ADMIN_PASSWORD=CHANGE_ME_admin_password
# Utilisateur operator (optionnel — peut soumettre des missions)
# JARVIS_OPERATOR_USER=operator
# JARVIS_OPERATOR_PASSWORD=CHANGE_ME_operator_password
# Utilisateur viewer (optionnel — lecture seule)
# JARVIS_VIEWER_USER=viewer
# JARVIS_VIEWER_PASSWORD=CHANGE_ME_viewer_password

# ── Rate Limiting (optionnel) ────────────────────────────────
# Mettre à true pour utiliser Redis comme backend rate limit (multi-instances)
RATE_LIMIT_REDIS=false

# ── CORS (API security) ─────────────────────────────────────
# Comma-separated origins. Empty = default localhost whitelist.
# CORS_ORIGINS=https://app.jarvismax.com,http://localhost:3000

# ── Observability (optional) ─────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=JarvisMax
LANGCHAIN_API_KEY=

# ── Docker Memory Limits ─────────────────────────────────────
OLLAMA_MEMORY_LIMIT=8g
JARVIS_MEMORY_LIMIT=4g

# ── Uncensored Mode (local-only) ─────────────────────────────
UNCENSORED_MODE=false

# ── OpenRouter (multi-model cloud gateway) ──────────────────────────────────
# Sign up at https://openrouter.ai — one key routes to 200+ models.
OPENROUTER_API_KEY=SET_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_FAST=mistralai/mistral-7b-instruct
OPENROUTER_MODEL_STANDARD=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_STRONG=anthropic/claude-sonnet-4

# ── Telegram APK Delivery ───────────────────────────────────────────────────
# Only needed for automated APK delivery to Telegram.
TELEGRAM_BOT_TOKEN=SET_ME
TELEGRAM_TARGET_CHAT_ID=SET_ME

# ── Model Strategy (stability-first) ────────────────────────────────────────
# Heavy roles → Claude Sonnet 4.5
ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4.5
ARCHITECT_MODEL=anthropic/claude-sonnet-4.5
CODER_MODEL=anthropic/claude-sonnet-4.5
SELF_IMPROVEMENT_MODEL=anthropic/claude-sonnet-4.5
# Light roles → GPT-4o Mini
FAST_MODEL=openai/gpt-4o-mini
FALLBACK_MODEL=openai/gpt-4o-mini
VISION_MODEL=openai/gpt-4o-mini
# Experimental (optional)
EXPERIMENTAL_AGENT_MODEL=minimax/minimax-m2.7
