# JARVIS MAX — Git ignore

# ── Secrets (JAMAIS committer) ──────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ── Données runtime ──────────────────────────────────────────
logs/
workspace/projects/
workspace/reports/
workspace/missions/
workspace/patches/
workspace/.backups/
workspace/sandboxes/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
dist/
build/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Docker ───────────────────────────────────────────────────
.docker/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Patch journal / debug ────────────────────────────────────
workspace/patch_journal.jsonl

# ── Workspace runtime (DB WAL/SHM, logs) ─────────────────────
workspace/*.log
workspace/*.db-shm
workspace/*.db-wal
workspace/api.log
workspace/build.log
workspace/rebuild.log
workspace/goals.json
workspace/missions.json

# ── JVM / Android heap dumps ─────────────────────────────────
*.hprof
android/java_*.hprof
jarvismax_app/android/*.hprof

# ── Flutter build artifacts ───────────────────────────────────
jarvismax_app/build/
jarvismax_app/.dart_tool/
jarvismax_app/.flutter-plugins
jarvismax_app/.flutter-plugins-dependencies
jarvismax_app/android/.gradle/
jarvismax_app/android/local.properties
jarvismax_app/android/app/debug/
jarvismax_app/android/app/release/
jarvismax_app/android/app/profile/
jarvismax_app/android/captures/
jarvismax_app/android/*.hprof
jarvismax_app/android/java_*.hprof
jarvismax_app/ios/Pods/
jarvismax_app/ios/.symlinks/
jarvismax_app/ios/Flutter/App.framework/
jarvismax_app/ios/Flutter/Flutter.framework/
jarvismax_app/ios/Flutter/Flutter.podspec
jarvismax_app/ios/Flutter/Generated.xcconfig
jarvismax_app/ios/Flutter/ephemeral/
jarvismax_app/ios/Runner/GeneratedPluginRegistrant.*

# ── Logs généraux ─────────────────────────────────────────────
logs/
*.log

# ── Workspace runtime étendu ──────────────────────────────────
workspace/*.json
workspace/*.db-shm
workspace/*.db-wal
workspace/*.log

# ── Workspace DB + night reports ─────────────────────────────────────
workspace/*.db
workspace/night_reports/

# ── Claude Code interne ───────────────────────────────────────────────
.claude/
workspace/

# ── Build artifacts ─────────────────────────────────────────────
*.apk
*.aab
archive/legacy_apks/

# ── Env files ───────────────────────────────────────────────────
.env.production
**/.cxx/
/data/
