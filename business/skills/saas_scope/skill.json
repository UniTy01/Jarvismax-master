{"id":"saas_scope.basic","version":"1.0","name":"SaaS MVP Scope","description":"Define a minimal viable SaaS product: feature prioritization, scope reduction, risk-based trimming, and dependency awareness.","domain":"saas_scope","inputs":[{"name":"product_idea","type":"string","required":true,"description":"Product idea or concept"},{"name":"target_user","type":"string","required":false,"description":"Primary user persona"},{"name":"timeline","type":"string","required":false,"description":"Development timeline constraint","default":"4-8 weeks"}],"outputs":[{"name":"must_features","type":"list","description":"Must-have features for MVP launch"},{"name":"should_features","type":"list","description":"Should-have features (post-launch)"},{"name":"cut_features","type":"list","description":"Features explicitly excluded with reasoning"},{"name":"dependencies","type":"list","description":"Technical dependencies and integration requirements"},{"name":"risk_assessment","type":"list","description":"Technical and market risks for the MVP"},{"name":"dev_estimate","type":"json","description":"Development time estimate by component"}],"dependencies":["persona.basic"],"quality_checks":[{"name":"scope_bounded","check_type":"completeness","threshold":0.8},{"name":"features_prioritized","check_type":"structure","threshold":0.7}],"tags":["saas","mvp","scope","features"]}
